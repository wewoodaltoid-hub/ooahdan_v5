{
  "expo": {
    "name": "ooahdan",
    "slug": "ooahdan",
    "version": "3.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ooahdan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "단어 놀이 영상 녹화를 위해 카메라 접근이 필요해요.",
          "microphonePermission": "영상에 소리를 담기 위해 마이크 접근이 필요해요.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "아카이브 영상을 갤러리에 저장하기 위해 사진 라이브러리 접근이 필요해요.",
          "savePhotosPermission": "아카이브 영상을 갤러리에 저장하기 위해 저장 권한이 필요해요."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
